//@version=6
indicator("AT — Filtro ATR", shorttitle="AT Filter", overlay=false, precision=2)

// ============================================================================
// INPUTS
// ============================================================================

grp = "⚙️ Configuración"
atrLen    = input.int(14, "ATR Length", minval=1, group=grp,
     tooltip="Período del ATR. Default: 14 velas H1.")
atrThresh = input.float(0.40, "Umbral Mínimo %", minval=0.05, maxval=2.0,
     step=0.05, group=grp,
     tooltip="Si ATR% < este valor → señal de baja calidad, no operar.\n0.40% = sweet spot (backtest 64 trades: WR 77.3%, DD -33%).")

grpVis = "🎨 Visual"
showBG   = input.bool(true, "Fondo rojo en zona peligro", group=grpVis)
showFill = input.bool(true, "Relleno bajo el umbral", group=grpVis)

// ============================================================================
// CÁLCULOS
// ============================================================================

atrRaw = ta.atr(atrLen)
atrPct = (atrRaw / close) * 100
atrOK  = atrPct >= atrThresh

// ============================================================================
// PLOTS
// ============================================================================

// ATR % como barras de columna
atrCol = atrOK ? color.new(#22C55E, 20) : color.new(#EF4444, 20)
pATR = plot(atrPct, "ATR %", color=atrCol, style=plot.style_columns, linewidth=2)

// Línea de umbral
pThresh = plot(atrThresh, "Umbral", color=color.new(#F59E0B, 40),
     linewidth=1, style=plot.style_line)

// Relleno entre ATR y umbral cuando está por debajo (zona peligro)
fillCol = showFill and not atrOK ? color.new(#EF4444, 80) : na
fill(pATR, pThresh, color=fillCol, title="Zona peligro")

// Background rojo suave cuando ATR está bajo
bgcolor(showBG and not atrOK ? color.new(#EF4444, 90) : na, title="BG Peligro")

// ============================================================================
// TABLA DE ESTADO
// ============================================================================

if barstate.islast
    var tbl = table.new(position.top_right, 2, 3,
         bgcolor=color.new(#111827, 5),
         border_color=color.new(#1F2937, 0),
         border_width=1,
         frame_color=color.new(#1F2937, 0),
         frame_width=1)

    // Título
    table.cell(tbl, 0, 0, "AT Filter", text_color=color.new(#3B82F6, 0), text_size=size.small, bgcolor=color.new(#0B1220, 0))
    statusTxt = atrOK ? "✅ OPERAR" : "🚫 NO OPERAR"
    statusCol = atrOK ? color.new(#22C55E, 0) : color.new(#EF4444, 0)
    table.cell(tbl, 1, 0, statusTxt, text_color=statusCol, text_size=size.small, bgcolor=color.new(#0B1220, 0))

    // ATR actual
    table.cell(tbl, 0, 1, "ATR " + str.tostring(atrLen), text_color=color.new(#9CA3AF, 0), text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(atrPct, "#.##") + "%", text_color=atrCol, text_size=size.small)

    // Umbral
    table.cell(tbl, 0, 2, "Umbral", text_color=color.new(#6B7280, 0), text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(atrThresh, "#.##") + "%", text_color=color.new(#F59E0B, 0), text_size=size.small)

// ============================================================================
// ALERTAS
// ============================================================================

alertcondition(not atrOK[1] and atrOK,
     title="Volatilidad recuperada",
     message="ATR volvió a superar el umbral. Señales habilitadas.")

alertcondition(atrOK[1] and not atrOK,
     title="Volatilidad baja",
     message="ATR cayó por debajo del umbral. Ignorar señales.")
